use v6.d;
use lib 'lib';
use Test;
use MVC::Keayl::TestSupport;
use MVC::Keayl::Dispatcher;
use MVC::Keayl::Router;
use MVC::Keayl::Routing;
use MVC::Keayl::Controller;
use MVC::Keayl::Mailer;
use MVC::Keayl::Mailer::Delivery::Test;
use MVC::Keayl::Job;
use MVC::Keayl::Job::QueueAdapter::Test;
use MVC::Keayl::Cable::PubSub::InMemory;
use MVC::Keayl::Cable::Connection;
use MVC::Keayl::Cable::Channel;

class CounterController is MVC::Keayl::Controller {
  method bump {
    self.session<count> = (self.session<count> // 0) + 1;
    self.render(plain => 'count=' ~ self.session<count>);
  }

  method go { self.redirect-to('/landing') }

  method landing { self.render(plain => 'you have landed') }

  method widgets { self.render(html => '<ul><li>Gizmo</li></ul>') }
}

class ShowController is MVC::Keayl::Controller {
  method show {
    self.assign('widget', 'gizmo');
    self.render('show');
  }
}

sub session(--> IntegrationSession) {
  my $router = routes {
    get '/bump',     to => 'counter#bump';
    get '/go',       to => 'counter#go';
    get '/landing',  to => 'counter#landing';
    get '/widgets',  to => 'counter#widgets';
  };
  my $dispatcher = MVC::Keayl::Dispatcher.new(
    :$router,
    controllers => [CounterController],
    controller-options => %( secret => 'integration-secret' ),
  );

  IntegrationSession.new(app => $dispatcher)
}

# in-process requests

{
  my $session = session;
  my $response = $session.get('/widgets');

  is $response.status, 200, 'a get request drives the dispatch stack';
  like $response.body, /Gizmo/, 'the response body is available';
}

# session and cookie persistence

{
  my $session = session;
  $session.get('/bump');
  $session.get('/bump');
  my $response = $session.get('/bump');

  is $response.body, 'count=3', 'the session persists across requests through the cookie jar';
}

# follow-redirect

{
  my $session = session;
  $session.get('/go');

  is $session.response.status, 302, 'a redirect response is returned';

  $session.follow-redirect;
  is $session.response.body, 'you have landed', 'follow-redirect issues the redirected request';
}

# response assertions

{
  my $session = session;
  $session.get('/widgets');

  lives-ok { $session.assert-response(200) }, 'assert-response passes for a matching status';
  lives-ok { $session.assert-response('ok') }, 'assert-response accepts a status name';
  dies-ok  { $session.assert-response(404) }, 'assert-response fails for a mismatched status';

  lives-ok { $session.assert-select('Gizmo') }, 'assert-select passes when the body matches';
  lives-ok { $session.assert-select(/'<li>' \w+ '</li>'/) }, 'assert-select accepts a regex';
  dies-ok  { $session.assert-select('Missing') }, 'assert-select fails when the body does not match';
}

{
  my $session = session;
  $session.get('/go');

  lives-ok { $session.assert-redirected-to('/landing') }, 'assert-redirected-to passes for the right location';
  dies-ok  { $session.assert-redirected-to('/elsewhere') }, 'assert-redirected-to fails for the wrong location';
}

# routing assertions

{
  my $router = routes {
    get  '/widgets/:id', to => 'widgets#show', as => 'widget';
    post '/widgets',     to => 'widgets#create';
  };

  lives-ok { assert-recognizes($router, 'GET', '/widgets/5', matching => %( controller => 'widgets', action => 'show', id => '5' )) },
    'assert-recognizes matches a route, action, and params';
  dies-ok { assert-recognizes($router, 'GET', '/nope') }, 'assert-recognizes fails for an unrecognized path';

  lives-ok { assert-generates($router, 'widget', '/widgets/5', 5) }, 'assert-generates builds the expected path';
  dies-ok  { assert-generates($router, 'widget', '/widgets/9', 5) }, 'assert-generates fails for the wrong path';

  lives-ok { assert-routing($router, 'widget', 'GET', '/widgets/5', matching => %( action => 'show' ), 5) },
    'assert-routing checks recognition and generation together';
}

# controller and view introspection

{
  my $renderer = RecordingRenderer.new;
  my $controller = ShowController.new(view-renderer => $renderer);
  $controller.dispatch('show');

  lives-ok { assert-rendered($renderer, 'show') }, 'assert-rendered finds the rendered template';
  dies-ok  { assert-rendered($renderer, 'edit') }, 'assert-rendered fails for an unrendered template';
  lives-ok { assert-assigned($controller, 'widget', 'gizmo') }, 'assert-assigned reads an assigned value';
  dies-ok  { assert-assigned($controller, 'widget', 'other') }, 'assert-assigned fails for a mismatched value';
}

# mailer helpers

{
  MVC::Keayl::Mailer::Delivery::Test.clear;

  my class PingMailer is MVC::Keayl::Mailer {
    method ping { self.mail(to => 'a@x.com', subject => 'Ping') }
  }
  my $mailer = PingMailer.new(delivery => MVC::Keayl::Mailer::Delivery::Test.new);

  lives-ok { assert-emails(1, { $mailer.deliver('ping') }) }, 'assert-emails counts a delivered email';
  dies-ok  { assert-emails(2, { $mailer.deliver('ping') }) }, 'assert-emails fails on the wrong count';
  lives-ok { assert-no-emails({ Nil }) }, 'assert-no-emails passes when nothing is delivered';

  MVC::Keayl::Mailer::Delivery::Test.clear;
}

# job helpers

{
  my class RecordJob is MVC::Keayl::Job {
    method perform($sink, $value) { $sink.push: $value }
  }

  my $adapter = MVC::Keayl::Job::QueueAdapter::Test.new;
  MVC::Keayl::Job.queue-adapter($adapter);

  my @ran;
  lives-ok { assert-enqueued-jobs(2, $adapter, { RecordJob.perform-later(@ran, 1); RecordJob.perform-later(@ran, 2) }) },
    'assert-enqueued-jobs counts enqueued jobs';

  perform-enqueued-jobs($adapter);
  is @ran, [1, 2], 'perform-enqueued-jobs runs the enqueued jobs';

  MVC::Keayl::Job.reset-queue-adapter;
}

# cable helpers

{
  my $pubsub = MVC::Keayl::Cable::PubSub::InMemory.new;

  lives-ok { assert-broadcasts($pubsub, 'room:1', 2, { $pubsub.broadcast('room:1', 'a'); $pubsub.broadcast('room:1', 'b') }) },
    'assert-broadcasts counts the broadcasts on a stream';
  dies-ok { assert-broadcasts($pubsub, 'room:1', 1, { $pubsub.broadcast('room:1', 'a'); $pubsub.broadcast('room:1', 'b') }) },
    'assert-broadcasts fails on the wrong count';
}

{
  my $pubsub = MVC::Keayl::Cable::PubSub::InMemory.new;
  my $conn = MVC::Keayl::Cable::Connection.new(:$pubsub, sink => -> $m { });

  my class RoomChannel is MVC::Keayl::Cable::Channel {
    method subscribed { self.stream-from('room:1') }
  }
  my $channel = RoomChannel.new(connection => $conn);
  $conn.add-subscription($channel);

  lives-ok { assert-stream-subscribed($channel, 'room:1') }, 'assert-stream-subscribed finds a streamed channel';
  dies-ok  { assert-stream-subscribed($channel, 'room:2') }, 'assert-stream-subscribed fails for an unstreamed name';
}

done-testing;
